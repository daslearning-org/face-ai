# main_layout.kv
## import local components
#:import FaceRecBox screens.face_match.FaceRecBox
#:import SettingsBox screens.setting.SettingsBox
#:import InitBox screens.init_screen.InitBox
#:import parse_color kivy.parser.parse_color

<DrawerClickableItem@MDNavigationDrawerItem>
    focus_color: "#e7e4c0"
    text_color: "#4a4939"
    icon_color: "#4a4939"
    ripple_color: "#c5bdd2"
    selected_color: "#0c6c4d"

<DrawerLabelItem@MDNavigationDrawerItem>
    text_color: "#4a4939"
    icon_color: "#4a4939"
    focus_behavior: False
    selected_color: "#4a4939"
    _no_ripple_effect: True

<ContentNavigationDrawer>

    MDNavigationDrawerHeader:
        title: "App Menu"
        title_color: "#4a4939"
        spacing: "4dp"
        padding: "12dp", 0, 0, "56dp"

    MDNavigationDrawerLabel:
        text: "Go To"

    DrawerClickableItem:
        icon: "bluetooth"
        text: "Initialize"
        on_press:
            root.nav_drawer.set_state("close")
            root.screen_manager.current = "initScreen"

    DrawerClickableItem:
        icon: "power"
        text: "Main App"
        on_press:
            root.nav_drawer.set_state("close")
            root.screen_manager.current = "mainAppScr"

    DrawerClickableItem:
        icon: "wrench"
        text: "Settings & Help"
        on_press:
            root.nav_drawer.set_state("close")
            root.screen_manager.current = "settingsScr"

## Main screen
MDScreen:

    MainScreenBox: # main container
        orientation: 'vertical'
        spacing: dp(4)
        padding: 0, self.top_pad, 0, 0 #self.bottom_pad

        MDTopAppBar:
            pos_hint: {"top": 1}
            elevation: 4
            title: "Face AI"
            left_action_items: [["menu", lambda x: nav_drawer.set_state("open")]]
            md_bg_color: '#874bd1'

        MDNavigationLayout:

            MDScreenManager:
                id: screen_manager

                MDScreen:
                    name: "initScreen"
                    InitBox:
                        id: init_screen

                MDScreen:
                    name: "mainAppScr"
                    #on_enter: app.acquire_wakelock()
                    #on_leave: app.release_wakelock()
                    FaceRecBox:
                        id: app_box

                MDScreen:
                    name: "settingsScr"
                    SettingsBox:
                        id: settings_box

            MDNavigationDrawer:
                id: nav_drawer
                radius: (0, 16, 16, 0)

                ContentNavigationDrawer:
                    screen_manager: screen_manager
                    nav_drawer: nav_drawer

# End
